{
  "name": "orthodoxconnect",
  "version": "1.0.0",
  "description": "Enterprise SaaS Church Management and FinTech platform for Orthodox Christian jurisdictions",
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "vercel-build": "prisma generate && cd frontend && npm install && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "orthodox",
    "church-management",
    "multi-tenant"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcrypt": "^5.1.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "selfsigned": "^5.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^6.9.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
