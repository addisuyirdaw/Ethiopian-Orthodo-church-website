{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "includeFiles": "prisma/schema.prisma"
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api" },
    { "source": "/api/v1/:path*", "destination": "/api" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
