{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "functions": {
    "api/index.ts": {
      "includeFiles": "prisma/schema.prisma"
    }
  },
  "routes": [
    { "src": "/health", "dest": "api/index.ts" },
    { "src": "/api/v1/(.*)", "dest": "api/index.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
